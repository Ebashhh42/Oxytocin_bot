# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Supabase project URL and anon/service-role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# The public URL of your Render service (no trailing slash)
# Example: https://oxytocin-bot.onrender.com
WEBHOOK_URL=https://your-render-service.onrender.com
